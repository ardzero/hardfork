{
  "name": "hardfork",
  "description": "A utility CLI that lets you hard-fork/nuke/revert/merge histories on a GitHub/GitLab repo with interactive promts.",
  "keywords": [
    "cli",
    "git",
    "fork",
    "github",
    "gitlab",
    "bunx",
    "hard fork",
    "nuke",
    "revert",
    "merge",
    "history",
    "git",
    "github",
    "gitlab",
    "remote",
    "fork",
    "npx",
    "hardfork"
  ],
  "homepage": "https://github.com/ardzero/hardfork",
  "bugs": {
    "url": "https://github.com/ardzero/hardfork/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ardzero/hardfork.git"
  },
  "author": "Ard Astroid <ardastroid@gmail.com>",
  "version": "0.0.4",
  "license": "MIT",
  "type": "module",
  "bin": {
    "hardfork": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/cli.js",
  "module": "src/cli.ts",
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --outdir dist --target node --minify --sourcemap=external",
    "gen:publish-workflow": "bun run publish-workflow-gen.ts",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@clack/prompts": "^1.3.0",
    "@types/bun": "latest",
    "@types/node": "^25.6.0",
    "@types/yargs": "^17.0.35",
    "execa": "^9.6.1",
    "picocolors": "^1.1.1",
    "yargs": "^18.0.0"
  }
}
